# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Required — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required for chat — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Your name — used by DEWD to address you in chat
OWNER_NAME=Your Name

# Optional — Gmail IMAP access for inbox widget
# Use an App Password, not your account password
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional — your city for the weather widget
WEATHER_LOCATION=New York, NY

# Optional — ntfy.sh topic for push alerts (leave blank to disable)
# Install the ntfy app and subscribe to this topic name
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh

# Dashboard auth — used for desktop browser login
# Generate a random SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
DASHBOARD_PASSWORD=change-me
